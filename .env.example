# ============================================================
# Environment Configuration Template
# ============================================================
# Copy this file to .env.local and fill in your credentials
# Run: cp .env.example .env.local
#
# Never commit .env.local or any real secrets to version control!
# ============================================================

# ============================================================
# Application
# ============================================================
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=My SaaS App
# Set to "true" to run in demo mode (no DB, Stripe, Resend, or auth backend needed)
# NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_APP_URL=http://localhost:3003

# ============================================================
# Database — PostgreSQL via Drizzle ORM
# ============================================================
# Supabase: Settings → Database → Connection string (URI mode)
# Neon / Railway / local postgres also work.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp

# Supabase project URL + anon key — only needed if you use
# Supabase Storage, Realtime, or other non-Postgres features.
# The app's primary DB access goes through DATABASE_URL above.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# ============================================================
# Auth — Better-Auth
# https://better-auth.com
# ============================================================
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3003

# ============================================================
# Payments — Stripe (Web)
# https://dashboard.stripe.com/apikeys
# ============================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhooks → Developers → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
# Products → find your price IDs
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ============================================================
# Email — Resend
# https://resend.com/api-keys
# ============================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# Rate Limiting — Upstash Redis
# https://console.upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ============================================================
# Analytics — PostHog
# https://us.posthog.com/settings/project
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ============================================================
# Error Tracking — Sentry
# https://sentry.io/settings/projects
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...

# ============================================================
# Background Jobs — Inngest
# https://app.inngest.com/env/production/manage/keys
# ============================================================
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-prod-...

# ============================================================
# Tracing — OpenTelemetry (optional)
# ============================================================
# OTLP HTTP endpoint, e.g. Grafana Tempo / Honeycomb / Jaeger
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ============================================================
# Canary Rollouts — Vercel Edge Config (optional)
# ============================================================
# Auto-injected by Vercel when you link an Edge Config store.
# EDGE_CONFIG=https://edge-config.vercel.com/ecfg_xxx?token=xxx

# ─── Leash ──────────────────────────────────────────────────────────
# Control plane: ed25519 PKCS8 PEM private key used to SIGN policies.
# Generate a keypair with:  node scripts/gen-leash-keys.mjs
LEASH_POLICY_SIGNING_KEY=""

# leashd (sidecar, set on the machine running it):
#   LEASH_CONTROL_PLANE_URL=http://localhost:3003
#   LEASH_CONTROL_PLANE_PUBKEY=<base64 SPKI DER, from gen-leash-keys.mjs>
#   LEASH_WORKSPACE_ID=<from control plane>
#   LEASH_AGENT_ID=<from control plane>
#   LEASH_AGENT_TOKEN=<one-time token shown when you create the agent>
#   LEASH_NWC_URL=nostr+walletconnect://...   (Lightning rail; secret, stays local)
#   LEASH_CASHU_MINT_URL=https://mint.example   (Cashu ecash rail; balance/proofs stay local)
#   LEASH_X402_PRIVATE_KEY=0x...               (x402 stablecoin rail; EVM key, secret, stays local)
#   LEASH_X402_NETWORK=base                     (x402 network; default base)
